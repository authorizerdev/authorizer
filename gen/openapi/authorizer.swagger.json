        },
        "authenticator_secret": {
          "type": "string"
        },
        "authenticator_recovery_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "description": "AuthResponse mirrors the GraphQL AuthResponse type. Returned (wrapped) by\nevery method that produces a session: Signup, Login, MagicLinkLogin,\nVerifyEmail, VerifyOtp, Session."
